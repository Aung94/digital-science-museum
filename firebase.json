{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "CLAUDE.md",
      "**/node_modules/**",
      "**/.git/**"
    ],
    "headers": [
      {
        "source": "**/*.js",
        "headers": [{"key": "Cache-Control", "value": "public, max-age=3600"}]
      },
      {
        "source": "**/*.css",
        "headers": [{"key": "Cache-Control", "value": "public, max-age=3600"}]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
